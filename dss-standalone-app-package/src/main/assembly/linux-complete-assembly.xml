<?xml version="1.0"?>
<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">

    <id>linux-complete-tar</id>

    <formats>
        <format>tar.gz</format>
    </formats>

    <baseDirectory></baseDirectory>

    <fileSets>

        <fileSet>
            <directory>${project.build.directory}/java-linux/${jre.root.folder}</directory>
            <fileMode>0755</fileMode>
            <outputDirectory>java</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}/fx-sdk-linux/${fx.root.folder}</directory>
            <fileMode>0755</fileMode>
            <outputDirectory>fx-sdk</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>src/main/resources/linux-complete</directory>
            <fileMode>0755</fileMode>
            <outputDirectory></outputDirectory>
        </fileSet>
        <fileSet>
            <directory>target</directory>
            <outputDirectory></outputDirectory>
            <includes>
                <include>dss-app.jar</include>
            </includes>
        </fileSet>

    </fileSets>

</assembly>